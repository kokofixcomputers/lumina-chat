{
  "name": "my-ai-chat",
  "main": "src/index.js",
  "compatibility_date": "2026-01-01",
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_USER",
        "class_name": "UserStore"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatUser"]
    },
    {
      "tag": "v2",
      "renamed_classes": [
        { "from": "ChatUser", "to": "UserStore" }
      ]
    }
  ]
}