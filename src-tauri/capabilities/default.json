{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:allow-write-text-file",
    "opener:default",
    "dialog:default",
    "fs:allow-write-file",
    "http:default",
    "http:allow-fetch",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://**" },
        { "url": "https://enter.pollinations.ai/**" },
	      { "url": "http://localhost:1234/**" }
      ]
    }
  ]
}
