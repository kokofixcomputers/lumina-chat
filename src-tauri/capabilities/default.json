{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "onedrive-oauth"
  ],
  "remote": {
    "urls": [
      "https://**",
      "http://**"
    ]
  },
  "permissions": [
    "core:default",
    "deep-link:default",
    "fs:allow-write-text-file",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "shell:allow-spawn",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "sh", "cmd": "sh", "args": true }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "/**" }, { "path": "*" }]
    },
    "core:webview:allow-create-webview-window",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://**" },
        { "url": "https://enter.pollinations.ai/**" },
        { "url": "http://localhost:1234/**" },
        { "url": "http://*:*" }
      ]
    }
  ]
}