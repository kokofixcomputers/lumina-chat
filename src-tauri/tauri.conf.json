{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lumina Chat",
  "version": "0.1.0",
  "identifier": "cc.kokodev.luminachat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Lumina Chat",
        "width": 1480,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deepLink": {
      "all": false,
      "windows": [
        {
          "protocols": [
            {
              "name": "Lumina Chat Deep Link",
              "schemes": ["lumina"],
              "role": "Viewer"
            }
          ]
        }
      ],
      "macOS": {
        "bundleId": "cc.kokodev.luminachat",
        "schemes": ["lumina"]
      },
      "linux": {
        "mimeTypes": [
          {
            "comment": "Lumina Chat Deep Link",
            "glob": ["lumina:*"],
            "mimeType": "x-scheme-handler/lumina"
          }
        ]
      }
    }
  }
}
